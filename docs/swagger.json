{
    "swagger": "2.0",
    "info": {
        "description": "Backend API for Crossword App",
        "title": "Crossword API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {},
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/crossword": {
            "get": {
                "description": "Returns crossword grid data and clues from JSON file",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Crossword"
                ],
                "summary": "Get today's crossword",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.Crossword"
                        }
                    },
                    "500": {
                        "description": "Crossword not found or parse error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/leaderboard": {
            "get": {
                "description": "Returns a list of users sorted by score in descending order",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Leaderboard"
                ],
                "summary": "Get leaderboard",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.User"
                            }
                        }
                    },
                    "500": {
                        "description": "Database error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/submitcrossword": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Stores or updates a user’s crossword answers. Requires JWT authentication.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Crossword"
                ],
                "summary": "Submit crossword answers",
                "parameters": [
                    {
                        "description": "Crossword answer data",
                        "name": "crossword",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.CrosswordAnswer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Answer stored",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request format",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized or missing token",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Database error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/users/login": {
            "post": {
                "description": "Returns JWT token if user exists",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Log in existing user",
                "parameters": [
                    {
                        "description": "User login info",
                        "name": "user",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.User"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful login",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid request format",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "401": {
                        "description": "User not registered",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/users/register": {
            "post": {
                "description": "Creates a new user if not registered and returns a JWT token. If already registered, returns the user(no JWT token)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Register a new user",
                "parameters": [
                    {
                        "description": "User info",
                        "name": "user",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.User"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "User successfully registered",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid request format",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Database or token error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.Cell": {
            "type": "object",
            "properties": {
                "isBlank": {
                    "type": "boolean"
                },
                "numberAssociated": {
                    "type": "integer"
                }
            }
        },
        "model.Clues": {
            "type": "object",
            "properties": {
                "across": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.UnitClue"
                    }
                },
                "down": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.UnitClue"
                    }
                }
            }
        },
        "model.Crossword": {
            "type": "object",
            "properties": {
                "clues": {
                    "$ref": "#/definitions/model.Clues"
                },
                "columns": {
                    "type": "integer"
                },
                "grid": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "$ref": "#/definitions/model.Cell"
                        }
                    }
                },
                "rows": {
                    "type": "integer"
                }
            }
        },
        "model.CrosswordAnswer": {
            "type": "object"
        },
        "model.UnitClue": {
            "type": "object",
            "properties": {
                "clueID": {
                    "type": "integer"
                },
                "clueText": {
                    "type": "string"
                }
            }
        },
        "model.User": {
            "type": "object"
        }
    }
}